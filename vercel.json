{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "exit 0",
  "redirects": [
    {
      "source": "/",
      "destination": "https://crtechweb.com.br/taskflow",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/taskflow/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/taskflow/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/taskflow",
      "destination": "/index.html"
    }
  ]
}
